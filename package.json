{
	"name": "emf-converter",
	"version": "1.4.1",
	"description": "Convert EMF/WMF metafile binaries to PNG data URLs using Canvas",
	"keywords": [
		"canvas",
		"converter",
		"emf",
		"metafile",
		"png",
		"windows-metafile",
		"wmf"
	],
	"homepage": "https://github.com/ChristopherVR/emf-converter",
	"bugs": {
		"url": "https://github.com/ChristopherVR/emf-converter/issues"
	},
	"license": "Apache-2.0",
	"author": "ChristopherVR",
	"repository": {
		"type": "git",
		"url": "https://github.com/ChristopherVR/emf-converter.git"
	},
	"files": [
		"dist/",
		"LICENSE",
		"README.md"
	],
	"main": "dist/index.js",
	"module": "dist/index.mjs",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.mjs",
			"require": "./dist/index.js"
		}
	},
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"typecheck": "tsc --noEmit --pretty",
		"test": "vitest run",
		"test:watch": "vitest",
		"pack": "bun run build && bun pm pack"
	},
	"devDependencies": {
		"tsup": "^8.5.1",
		"typescript": "^6.0.3",
		"vitest": "^4.1.8"
	}
}
